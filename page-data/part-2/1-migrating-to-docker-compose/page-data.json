55c","frontmatter":{"path":"/part-1/3-in-depth-dive-to-images","title":"In-depth dive to images"}}},{"node":{"id":"2e8cfa7d-acdf-569e-a905-821d1fc0c16e","frontmatter":{"path":"/part-3/1-deeper-understainding-of-containers","title":"Deeper understanding of containers"}}},{"node":{"id":"2962a7c7-e916-5c7a-9f00-eb844d6541bb","frontmatter":{"path":"/part-1/4-defining-start-conditions","title":"Defining start conditions for the container"}}},{"node":{"id":"436a4f22-5a0b-593b-a899-d682c63d8487","frontmatter":{"path":"/part-1/5-volumes-and-ports","title":"Interacting with the container via volumes and ports"}}},{"node":{"id":"cf1d3c45-f7be-57c3-934a-d7f924d68b44","frontmatter":{"path":"/part-1/2-running-and-stopping","title":"Running and stopping containers"}}}]}},"pageContext":{}},"staticQueryHashes":["3294351120","994120085"]}